# Shared
APP_ENV=local
TZ=Asia/Seoul

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_KAKAO_MAP_APP_KEY=

# Backend
BACKEND_PORT=8080
BACKEND_CORS_ALLOWED_ORIGINS=http://localhost:5173
BACKEND_PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_PUBLIC_BASE_URL=http://localhost:5173
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_CHAT_MODEL=gpt-5.4-nano

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=jiber
DB_USER=jiber
DB_PASSWORD=
DB_ROOT_PASSWORD=

# Database dump import
DB_DUMP_DRIVE_URL=https://drive.google.com/drive/folders/1G5HRQa7K-mPk8o5qguqqv2QaPGoFlGmJ?usp=drive_link
DB_DUMP_SELECTION=latest
DB_DUMP_SOURCE_DATABASE=Jiber
DB_DUMP_FORCE_DOWNLOAD=false
DB_DUMP_SKIP_DOWNLOAD=false
DB_DUMP_FORCE_IMPORT=false
DB_DUMP_SKIP_IMPORT=false

# Public data import
PUBLIC_DATA_SERVICE_KEY=
KAKAO_REST_API_KEY=
# Google News RSS. No API key is required, but the public RSS endpoint has no SLA.
GOOGLE_NEWS_RSS_BASE_URL=https://news.google.com/rss/search
GOOGLE_NEWS_RSS_HL=ko
GOOGLE_NEWS_RSS_GL=KR
GOOGLE_NEWS_RSS_CEID=KR:ko
PUBLIC_DATA_IMPORT_MONTHS=12
PUBLIC_DATA_TARGET_REGIONS=SEOUL,BUSAN
PUBLIC_DATA_IMPORT_ENABLED=false
PUBLIC_DATA_IMPORT_DRY_RUN=true
PUBLIC_DATA_IMPORT_LIMIT=100
PUBLIC_DATA_IMPORT_PAGE_SIZE=100

# JWT
JWT_ISSUER=jiber-local
JWT_SECRET=
JWT_ACCESS_TOKEN_TTL_SECONDS=900
JWT_REFRESH_TOKEN_TTL_SECONDS=1209600
AUTH_ACCESS_TOKEN_DELIVERY=response_body
AUTH_ACCESS_TOKEN_STORAGE=memory
AUTH_REFRESH_TOKEN_COOKIE_NAME=JIBER_REFRESH_TOKEN
AUTH_REFRESH_TOKEN_COOKIE_PATH=/api/v1/auth
AUTH_REFRESH_TOKEN_COOKIE_SAME_SITE=Lax
AUTH_REFRESH_TOKEN_COOKIE_SECURE=false
AUTH_REFRESH_TOKEN_ROTATION_ENABLED=true
AUTH_REFRESH_TOKEN_REVOCATION_STORE=db
AUTH_ADMIN_BOOTSTRAP_ENABLED=false
AUTH_ADMIN_BOOTSTRAP_EMAILS=

# OAuth2 - Google
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google

# OAuth2 - Kakao
OAUTH_KAKAO_CLIENT_ID=
OAUTH_KAKAO_CLIENT_SECRET=
OAUTH_KAKAO_REDIRECT_URI=http://localhost:8080/login/oauth2/code/kakao

# OAuth2 - Naver
OAUTH_NAVER_CLIENT_ID=
OAUTH_NAVER_CLIENT_SECRET=
OAUTH_NAVER_REDIRECT_URI=http://localhost:8080/login/oauth2/code/naver

# Model server
MODEL_SERVER_BASE_URL=http://localhost:8000
MODEL_SERVER_PORT=8000
MODEL_SERVER_INTERNAL_TOKEN=
MODEL_SERVER_CONNECT_TIMEOUT_MS=2000
MODEL_SERVER_READ_TIMEOUT_MS=5000
MODEL_VERSION=
MODEL_BASELINE_DATE=
MODEL_FEATURE_SET_VERSION=
VALUATION_DATA_DRIVE_URL=https://drive.google.com/drive/folders/1jdnBblDrBYiAWf1ZsXCz89tnLaTf4CiY?usp=drive_link
VALUATION_MODEL_DRIVE_URL=https://drive.google.com/file/d/19mv0MTkN03YA2cUUQqVGS6zhvar9dmf9/view?usp=drive_link
XAI_DRIVE_URL=https://drive.google.com/drive/folders/1KMv9Lep73c6DLpTSYuVGwpaSW7YetdLP?usp=drive_link
MODEL_ASSETS_FORCE_DOWNLOAD=false
MODEL_ASSETS_SKIP_DOWNLOAD=false
MODEL_ASSETS_SKIP_DATASET=false
MODEL_ASSETS_SKIP_MODEL=false
MODEL_ASSETS_SKIP_XAI=false
MODEL_ASSETS_ALLOW_PARTIAL_DOWNLOAD=false
