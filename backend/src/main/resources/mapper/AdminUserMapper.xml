<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jiber.backend.admin.AdminUserMapper">
    <resultMap id="AdminUserRowMap" type="com.jiber.backend.admin.AdminUserRow">
        <constructor>
            <idArg column="user_id" javaType="java.lang.Long"/>
            <arg column="email" javaType="java.lang.String"/>
            <arg column="display_name" javaType="java.lang.String"/>
            <arg column="role" javaType="java.lang.String"/>
            <arg column="enabled" javaType="java.lang.Boolean"/>
            <arg column="last_login_at" javaType="java.time.OffsetDateTime"/>
            <arg column="created_at" javaType="java.time.OffsetDateTime"/>
            <arg column="updated_at" javaType="java.time.OffsetDateTime"/>
        </constructor>
    </resultMap>

    <sql id="AdminUserColumns">
        user_id,
        email,
        display_name,
        role,
        enabled,
        last_login_at,
        created_at,
        updated_at
    </sql>

    <sql id="AdminUserFilters">
        1 = 1
        <if test="request.keyword != null and request.keyword.trim() != ''">
            AND (
                LOWER(email) LIKE CONCAT('%', LOWER(#{request.keyword}), '%')
                OR LOWER(display_name) LIKE CONCAT('%', LOWER(#{request.keyword}), '%')
            )
        </if>
        <if test="request.role != null and request.role.trim() != ''">
            AND role = #{request.role}
        </if>
        <if test="request.enabled != null">
            AND enabled = #{request.enabled}
        </if>
    </sql>

    <sql id="AdminUserOrder">
        ORDER BY
        <choose>
            <when test="request.sort == 'lastLoginAt,desc'">
                last_login_at DESC,
            </when>
            <otherwise>
                created_at DESC,
            </otherwise>
        </choose>
        user_id DESC
    </sql>

    <select id="findUsers" resultMap="AdminUserRowMap">
        SELECT
        <include refid="AdminUserColumns"/>
        FROM users
        WHERE
        <include refid="AdminUserFilters"/>
        <include refid="AdminUserOrder"/>
        LIMIT #{limit}
        OFFSET #{offset}
    </select>

    <select id="countUsers" resultType="long">
        SELECT COUNT(*)
        FROM users
        WHERE
        <include refid="AdminUserFilters"/>
    </select>

    <select id="findById" resultMap="AdminUserRowMap">
        SELECT
        <include refid="AdminUserColumns"/>
        FROM users
        WHERE user_id = #{userId}
    </select>

    <update id="updateRole">
        UPDATE users
        SET role = #{role},
            updated_at = CURRENT_TIMESTAMP(6)
        WHERE user_id = #{userId}
    </update>

    <update id="updateEnabled">
        UPDATE users
        SET enabled = #{enabled},
            updated_at = CURRENT_TIMESTAMP(6)
        WHERE user_id = #{userId}
    </update>
</mapper>
